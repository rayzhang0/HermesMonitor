# SMTP email settings for Hermes Monitor
# Gmail users usually need an app password, not the normal account password.
HERMES_SMTP_HOST=smtp.gmail.com
HERMES_SMTP_PORT=587
HERMES_SMTP_USERNAME=your_email@gmail.com
HERMES_SMTP_PASSWORD=your_app_password
HERMES_EMAIL_FROM=your_email@gmail.com
HERMES_EMAIL_TO=recipient@example.com
HERMES_FAILURE_EMAIL_TO=ops@example.com
